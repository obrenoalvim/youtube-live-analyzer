{
  "manifest_version": 3,
  "name": "YouTube Live Comment Analyzer",
  "version": "1.0",
  "description": "Analisa comentários de lives do YouTube em tempo real e cria ranking dos assuntos mais falados",
  
  "permissions": [
    "activeTab",
    "storage"
  ],
  
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content-script.js"],
      "css": ["styles.css"]
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Live Analyzer"
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}